---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Partner with APIOps Helsinki">
  <section class="hero hero--dark">
    <div class="container hero-grid">
      <div class="hero-content">
        <p class="eyebrow">PARTNER WITH APIOPS HELSINKI</p>

        <h1>
          Stop sponsoring impressions.<br />
          Start participating in API decisions.
        </h1>

        <p class="hero-sub">
          Join the room where API platform teams solve real problems —
          with the people building them.
        </p>

        <div class="hero-actions">
          <a href="/contact" class="btn btn-primary">Become a Partner</a>
          <a href="#participation" class="btn btn-secondary">How it works</a>
        </div>
      </div>

      <div class="hero-visual" aria-hidden="true">
        <div class="api-map">
          <div class="node center">APIs</div>
          <div class="node">Identity</div>
          <div class="node">Access</div>
          <div class="node">Contracts</div>
          <div class="node">Agents</div>
          <div class="node">Platforms</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="container three-col center-text">
      <div>
        <h3>Access</h3>
        <p>Direct conversations with platform teams.</p>
      </div>

      <div>
        <h3>Context</h3>
        <p>Real API constraints, not slideware.</p>
      </div>

      <div>
        <h3>Trust</h3>
        <p>Peer-level interaction. No vendor theatre.</p>
      </div>
    </div>
  </section>

  <section id="participation" class="section">
    <div class="container">
      <h2>How partners participate</h2>
      <p class="section-sub">
        You don’t sponsor visibility. You participate in solving problems.
      </p>

      <div class="card-grid three">
        <div class="card card--feature">
          <h3>Bring a customer case</h3>
          <p>
            Present real API, IAM, or platform challenges.
          </p>
          <ul>
            <li>Get feedback from practitioners</li>
            <li>Pressure-test your approach</li>
          </ul>
        </div>

        <div class="card card--feature">
          <h3>Join clinics</h3>
          <p>
            Work hands-on with teams in structured sessions.
          </p>
          <ul>
            <li>Direct interaction with decision-makers</li>
            <li>Understand real constraints</li>
          </ul>
        </div>

        <div class="card card--feature">
          <h3>Contribute experience</h3>
          <p>
            Share what works (and what doesn’t).
          </p>
          <ul>
            <li>No pitches</li>
            <li>Only real implementation insight</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--muted">
    <div class="container">
      <h2>Partnership levels</h2>
      <p class="section-sub">
        Packages define how deeply you engage — not how loud your logo is.
      </p>

      <div class="card-grid three">
        <div class="card">
          <h3>Supporter</h3>
          <ul>
            <li>Logo visibility</li>
            <li>Access to event</li>
          </ul>
        </div>

        <div class="card card--highlight">
          <h3>Partner</h3>
          <ul>
            <li>Bring a case</li>
            <li>Join clinics</li>
            <li>Community participation</li>
          </ul>
        </div>

        <div class="card">
          <h3>Leader</h3>
          <ul>
            <li>Keynote opportunity</li>
            <li>Roundtable access</li>
            <li>Strategic involvement</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container narrow">
      <div class="callout">
        <h3>This is not a lead generation event.</h3>

        <ul>
          <li>No sales pitches</li>
          <li>No attendee scraping</li>
          <li>No booth theatre</li>
        </ul>

        <p>
          If you want pipeline, this is the wrong event.<br />
          If you want relevance in API platform decisions, you should be here.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--dark">
    <div class="container center-text">
      <h2>Join the room where API decisions are made.</h2>

      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary">Become a Partner</a>
        <a href="/agenda" class="btn btn-secondary">See the agenda</a>
      </div>
    </div>
  </section>
</BaseLayout>
