    color: "magenta",
    line: "Platform Architecture",
    position: { left: 75, top: 52.5 },
    rotation: 1,
  },
  {
    id: "legal-and-compliance",
    name: "Legal and Compliance",
    problem: "regulatory impact",
    color: "magenta",
    line: "Platform Architecture",
    position: { left: 70, top: 50 },
    rotation: -1,
  },
  {
    id: "design-standards",
    name: "Design Standards",
    problem: "AI-assisted design consistency",
    color: "magenta",
    line: "Platform Architecture",
    position: { left: 80, top: 55 },
    rotation: 2,
  },
  {
    id: "api-consumer-adoption",
    name: "API Consumer Adoption",
    problem: "B2B developer migration",
    color: "cyan",
    line: "Publishing and Adoption",
    position: { left: 19, top: 43 },
    rotation: -2,
    featured: true,
  },
  {
    id: "monitoring-and-improving",
    name: "Monitoring and Improving",
    problem: "production adoption metrics",
    color: "cyan",
    line: "Publishing and Adoption",
    position: { left: 43, top: 43 },
    rotation: 1,
  },
];

const badgeExamples = [
  {
    name: "Anna",
    role: "Enterprise Architecture",
    stickers: ["Business Goals", "Portfolio Management"],
  },
  {
    name: "Marco",
    role: "Platform / Security",
    stickers: ["API Platform Architecture", "Security and Privacy"],
  },
  {
    name: "Priya",
    role: "Developer Ecosystem",
    stickers: ["API Consumer Adoption", "Design Standards"],
  },
];

const stickerByName = new Map(stationStickers.map((station) => [station.name, station]));

const audience = [
  "API strategy and program leaders",
  "API platform and API management owners",
  "Enterprise architects and integration leaders",
  "Developer experience and platform engineering teams",
  "Security, IAM, privacy, risk, legal, and compliance leaders",
  "AI-enabled digital capability and product teams",
  "B2B developer ecosystem and partner API owners",
  "Public-sector and regulated data-sharing practitioners",
];

const agenda = [
  {
    time: "8:45-9:15",
    title: "Breakfast, Networking, and APIOps Station Stickers",
    detail: "Choose the APIOps Cycles stations that match the problems you want to work on during the day.",
  },
  {
    time: "9:15-9:55",
    title: "Welcome and Opening Provocation",
    detail: "After API Management: why the hard part starts after the platform decision.",
  },
  {
    time: "9:55-10:40",
    title: "Practitioner Sparks and Station Marketplace",
    detail: "Short practitioner provocations, followed by participant voting on station clinic questions.",
  },
  {
    time: "11:00-12:15",
    title: "Station Clinics Round 1: Get the Story Straight",
    detail: "Work on leadership language, stakeholder understanding, shadow APIs, governance, and platform choices.",
  },
  {
    time: "12:15-13:00",
    title: "Guided Clinic: Find the First Proof Capability",
    detail: "Identify a narrowly scoped API, event, integration, or capability that can prove the operating model.",
  },
  {
    time: "14:15-15:15",
    title: "Station Clinics Round 2: Make the Change Happen",
    detail: "Move from diagnosis to operating-model interventions, owners, first 30 days, and evidence.",
