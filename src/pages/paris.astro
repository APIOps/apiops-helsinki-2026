---
import BaseLayout from "../layouts/BaseLayout.astro";

const ticketUrl =
  "https://portal.joinfost.io/event/future-of-software-technologies-paris-2026/5e27c773-7fa8-4169-b6a7-93494701212a/apiops-conference";
const challengeUrl = "https://tally.so/r/dWgy2D";
const contributorUrl = "https://tally.so/r/zxg8Wa";
const updatesUrl = "mailto:info@apiops.info?subject=APIOps%20Paris%202026%20program%20updates";
const partnershipUrl = "https://tally.so/r/3yQEpp";

const participationRoutes = [
  {
    title: "Attend",
    body: "Join the full-day APIOps Operating Model Day on December 1.",
    cta: "Get Early Bird Ticket",
    href: ticketUrl,
    note: "Tickets are sold through FOST/apidays.",
  },
  {
    title: "Share a challenge",
    body: "Tell us what API operating-model problem you want the room to work on.",
