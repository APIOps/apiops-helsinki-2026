    rotation: 1,
  },
  {
    id: "portfolio-management",
    name: "Portfolio Management",
    problem: "surface shadow APIs",
    color: "blue",
    line: "Operating Model",
    position: { left: 66.5, top: 25 },
    rotation: -1,
    featured: true,
  },
  {
