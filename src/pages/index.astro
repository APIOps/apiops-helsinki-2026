---
import BaseLayout from "../layouts/BaseLayout.astro";
import agenda from "../data/agenda.json";
import speakers from "../data/speakers.json";
import sponsors from "../data/sponsors.json";

const ticketUrl = "https://shop.osaango.com/category/apiops-helsinki-2026";
const speakerUrl = "https://tally.so/r/LZW5kO";
const partnerUrl =
  "https://docs.google.com/presentation/d/1bXmS1AlfLN40FQ6Ws6ldm9BffD1sS_BW/edit?usp=sharing&ouid=108887358045542967446&rtpof=true&sd=true";

const whoFor = [
  "Own or build an API platform in an enterprise",
  "Design APIs used by AI agents or automation",
  "Are responsible for governance, IAM, or monetization",
  "Need to align business, product, and platform teams",
];

const notFor = [
  "Want beginner-level API content",
  "Prefer vendor-driven presentations",
  "Don’t have real API challenges to solve",
];

const apiopsProblems = [
  "Our IAM model doesn’t work for AI agents",
  "Our API platform adoption is stalled",
  "Governance is slowing teams down",
  "We don’t know how to structure APIs as products",
  "We can’t connect API usage to business value",
  "Our APIs weren’t designed for agent-driven usage",
];

const problemSignals = [
  {
    title: "For platform owners",
    body: "Operating model, ownership, governance, and business value are unclear.",
    icon: "material-symbols-light:layers-outline",
  },
  {
    title: "For architects",
    body: "Identity, contracts, lifecycle, and platform boundaries aren’t holding up.",
    icon: "material-symbols-light:account-tree-outline",
  },
  {
    title: "For senior engineers",
    body: "MCP, agent integrations, reliability, and API behavior break under real usage.",
    icon: "material-symbols-light:code-blocks-outline",
  },
];

const formatBlocks = [
  {
    title: "Clinic",
    tag: "CLINIC",
    icon: "material-symbols-light:handyman-outline",
    body: "Bring your API, platform, or governance problem.",
    outcome: "Get direct input from experienced practitioners.",
    tone: "orange",
  },
  {
    title: "AI Lab",
    tag: "LAB",
    icon: "material-symbols-light:science-outline",
    body: "Test ideas around MCP, agent integrations, and AI workflows.",
    outcome: "Understand what actually works (and what breaks).",
    tone: "purple",
  },
  {
    title: "Unconference",
    tag: "UNCONFERENCE",
    icon: "material-symbols-light:sync-outline",
    body: "Topics are shaped by participants.",
    outcome: "Discuss what matters now, not what was planned months ago.",
    tone: "blue",
  },
];

const whyEventExists = [
  {
    icon: "material-symbols-light:smart-toy-outline",
    title: "APIs designed without APIOps break under AI usage",
    text: "Interfaces built for apps don’t handle autonomous agents, scale, or unpredictability.",
  },
  {
    icon: "material-symbols-light:api",
    title: "Governance, identity, and contracts become critical",
    text: "Without explicit control boundaries, agent behavior creates reliability, access, and compliance risks.",
  },
  {
    icon: "material-symbols-light:warning-outline",
    title: "Platform thinking becomes mandatory",
    text: "Teams need shared operating models, lifecycle governance, and clear ownership across APIs.",
  },
  {
    icon: "material-symbols-light:note-stack-outline",
    title: "Strategy must translate into execution",
    text: "APIOps turns decisions into repeatable practices and measurable platform outcomes.",
  },
];

const coverTopics = [
  {
    title: "Strategy",
    body: "Platform and product alignment across APIs",
    icon: "material-symbols-light:layers-outline",
  },
  {
    title: "Identity",
    body: "Auth models that work for agents, systems, and scale",
    icon: "material-symbols-light:shield-lock-outline",
  },
  {
    title: "Monetization",
    body: "Turning API usage into measurable business value",
    icon: "material-symbols-light:euro",
  },
  {
    title: "AI Agents",
    body: "APIs as inputs to autonomous systems",
    icon: "material-symbols-light:smart-toy-outline",
  },
];

const sessionToneMap = {
  KEYNOTE: "orange",
  "CASE STUDY": "purple",
  PANEL: "slate",
  CLINIC: "orange",
  "HANDS-ON": "purple",
  WORKSHOP: "purple",
  LAB: "purple",
  UNCONFERENCE: "blue",
  BREAK: "soft",
  LUNCH: "soft",
  CLOSING: "soft",
};

function getSessionTone(type) {
  return sessionToneMap[type] || "soft";
}

function inferSessionType(title = "") {
  const t = title.toLowerCase();

  if (t.includes("keynote")) return "KEYNOTE";
  if (t.includes("panel")) return "PANEL";
  if (t.includes("clinic")) return "CLINIC";
  if (t.includes("lab")) return "LAB";
  if (t.includes("unconference")) return "UNCONFERENCE";
  if (t.includes("hands-on")) return "HANDS-ON";
  if (t.includes("workshop")) return "WORKSHOP";
  if (t.includes("break")) return "BREAK";
  if (t.includes("lunch")) return "LUNCH";
  if (t.includes("closing")) return "CLOSING";

  return "";
}

function getSharedSessionType(item) {
  return item.sessionType || inferSessionType(item.title || "");
}
---

<BaseLayout title="APIOps Helsinki Conference 2026">
  <nav>
    <div class="container nav-inner">
      <div class="brand">
        <img class="brand-logo" src="/favicon-32x32.png" alt="APIOps Helsinki logo" />
        <strong>APIOps Helsinki</strong>
      </div>

      <button
        class="nav-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="top-navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-links" id="top-navigation">
        <a href="#agenda">Agenda</a>
        <a href="#format">Format</a>
        <a href="#speakers">Speakers</a>
        <a href="#partners">Partners</a>
        <a href={ticketUrl}>Tickets</a>
        <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
      </div>
    </div>
  </nav>

  <script>
    const navToggle = document.querySelector(".nav-toggle");
    const navLinks = document.querySelector(".nav-links");

    navToggle?.addEventListener("click", () => {
      navLinks?.classList.toggle("is-open");
      const isExpanded = navLinks?.classList.contains("is-open") || false;
      navToggle.setAttribute("aria-expanded", String(isExpanded));
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 720 && navLinks?.classList.contains("is-open")) {
        navLinks.classList.remove("is-open");
        navToggle?.setAttribute("aria-expanded", "false");
      }
    });
  </script>
  <script
    is:inline
    type="module"
    src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>

  <header class="hero hero-clean">
    <div class="container hero-layout">
      <div class="hero-copy">
        <span class="hero-kicker">APIOPS HELSINKI ·  June 2–3, 2026 · Epicenter Helsinki</span>
        <h1>APIOps Is Becoming<br />The Operating Model for APIs</h1>
        <p class="hero-meta">Most APIs were not designed for AI agents.</p>
        <p>
          A working event for people building and running API platforms.
        </p>
        <p>Bring an APIOps problem. Leave with clearer decisions.</p>
        <p class="hero-audience-line">
          For API platform leaders, architects, IAM owners, and product teams navigating AI-driven change.
        </p>

        <div class="hero-actions">
          <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
          <a class="button secondary" href={speakerUrl}>Bring an APIOps Problem</a>
        </div>

        <div class="trust-row">
          <span>Teams joining from:</span>
          <div class="trust-logos">
            <span>OP Financial Group</span>
            <span>ASSA ABLOY</span>
            <span>If Insurance</span>
            <span>Apiable</span>
          </div>
        </div>
        <p class="hero-selection-line">
          We’re selecting ~10–15 teams to work on real API platform challenges.
        </p>
        <p class="hero-problem-line">
          Typical problems: IAM for agents · platform adoption · governance · monetization
        </p>
      </div>

      <div class="hero-map hero-map-rich" aria-hidden="true">
        <div class="hero-map-grid"></div>
        <div class="hero-map-panel"></div>

        <div class="hero-map-core">APIs</div>

        <div class="hero-map-node hero-map-node-identity">
          <iconify-icon icon="material-symbols-light:badge-outline"></iconify-icon>
          <span>Identity</span>
        </div>

        <div class="hero-map-node hero-map-node-access">
          <iconify-icon icon="material-symbols-light:lock-outline"></iconify-icon>
          <span>Access</span>
        </div>

        <div class="hero-map-node hero-map-node-contracts">
          <iconify-icon icon="material-symbols-light:rule-outline"></iconify-icon>
          <span>Contracts</span>
        </div>

        <div class="hero-map-node hero-map-node-ai-agents">
          <iconify-icon icon="material-symbols-light:smart-toy-outline"></iconify-icon>
          <span>AI Agents</span>
        </div>

        <div class="hero-map-node hero-map-node-platforms">
          <iconify-icon icon="material-symbols-light:deployed-code-outline"></iconify-icon>
          <span>Platforms</span>
        </div>

        <div class="hero-map-node hero-map-node-business">
          <iconify-icon icon="material-symbols-light:business-center-outline"></iconify-icon>
          <span>Business</span>
        </div>

        <div class="hero-mini-card hero-mini-card-lab">
          <div class="hero-mini-card-tag hero-mini-card-tag-purple">LAB</div>
          <h4>MCP, agents, workflows</h4>
        </div>

        <div class="hero-mini-card hero-mini-card-clinic">
          <div class="hero-mini-card-tag hero-mini-card-tag-orange">CLINIC</div>
          <h4>Bring your IAM challenge</h4>
        </div>

        <div class="hero-mini-card hero-mini-card-keynote">
          <div class="hero-mini-card-tag hero-mini-card-tag-soft">KEYNOTE</div>
          <p class="hero-mini-time">09:00</p>
          <h4>From Ecosystem Design to API Strategy</h4>
          <p class="hero-mini-meta">Shared session</p>
        </div>

        <span class="hero-glow hero-glow-1"></span>
        <span class="hero-glow hero-glow-2"></span>
        <span class="hero-glow hero-glow-3"></span>
      </div>
    </div>
  </header>

  <section class="section section-light section-why" id="positioning">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>Why APIOps Matters Now</h2>
        </div>

        <div class="why-grid">
          {whyEventExists.map((item, index) => (
            <article class={`surface-card why-card ${index >= 2 ? "surface-card-soft" : ""}`}>
              <iconify-icon icon={item.icon} class="card-icon"></iconify-icon>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light" id="apiops-problems">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>What kind of APIOps problems?</h2>
          <p>We’re not looking for talks. We’re looking for real problems.</p>
        </div>

        <div class="problems-layout">
          <div class="surface-card problems-main-card">
            <ul class="problems-list">
              {apiopsProblems.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>

          <div class="problems-side-grid">
            {problemSignals.map((item) => (
              <article class="surface-card problem-signal-card">
                <iconify-icon icon={item.icon} class="card-icon"></iconify-icon>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-soft" id="who-for">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>Who This Is For</h2>
        </div>

        <div class="audience-grid">
          <article class="surface-card audience-card">
            <div class="audience-card-title">
              <iconify-icon icon="material-symbols-light:check-circle-outline"></iconify-icon>
              <h3>You should be here if you:</h3>
            </div>
            <ul>
              {whoFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>

          <article class="surface-card audience-card audience-card-muted">
            <div class="audience-card-title">
              <iconify-icon icon="material-symbols-light:cancel-outline"></iconify-icon>
              <h3>This is not for you if you:</h3>
            </div>
            <ul>
              {notFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>

        <div class="surface-card team-card">
          <h3>Best experienced as a team</h3>
          <p>
            This event works best when you bring 2–4 people from your organization: platform, IAM, product,
            and architecture.
          </p>
          <ul>
            <li>→ Align faster across roles</li>
            <li>→ Make decisions on the spot</li>
            <li>→ Avoid “conference → no change” syndrome</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-soft" id="format">
    <div class="container">
      <div class="section-shell">
        <div class="format-top">
          <div class="format-intro">
            <p class="format-kicker">This is APIOps in practice.</p>
            <h2>Two Days. One Goal.<br />Make Better API Decisions.</h2>
            <div class="format-signals">
              <div><iconify-icon icon="material-symbols-light:forum-outline"></iconify-icon><span>No slides without decisions</span></div>
              <div><iconify-icon icon="material-symbols-light:domain-verification-outline"></iconify-icon><span>Real problems from real teams</span></div>
              <div><iconify-icon icon="material-symbols-light:groups-outline"></iconify-icon><span>Workshops, clinics, open labs</span></div>
              <div><iconify-icon icon="material-symbols-light:smart-toy-outline"></iconify-icon><span>People running real platforms</span></div>
            </div>
          </div>

          <div class="format-cards">
            {formatBlocks.map((item) => (
              <article class={`surface-card format-card surface-card-accent-${item.tone}`}>
                <div class="format-card-top">
                  <iconify-icon icon={item.icon} class="card-icon"></iconify-icon>
                  <span class={`session-type session-type-${item.tone}`}>{item.tag}</span>
                </div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
                <p class="arrow-line">→ {item.outcome}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light section-system-map" id="program-narrative">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>What We’ll Cover</h2>
        </div>

        <div class="cover-grid">
          {coverTopics.map((item) => (
            <article class="surface-card cover-card">
              <iconify-icon
                icon={item.icon}
                class={`card-icon ${
                  item.title === "Identity"
                    ? "identity"
                    : item.title === "Monetization"
                      ? "monetization"
                      : item.title === "AI Agents"
                        ? "ai"
                        : ""
                }`}></iconify-icon>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-soft" id="bring-problem">
    <div class="container">
      <div class="section-shell bring-problem-shell">
        <div class="bring-problem-content">
          <div class="small-pill">Working Session</div>
          <h2>Bring a Real APIOps Problem</h2>
          <p class="bring-problem-lead">
            This is not a passive conference. You’ll work on real APIOps decisions with people solving similar
            challenges.
          </p>
          <p>
            Bring a problem around APIs, IAM, platform design, or governance — and get direct input from
            practitioners.
          </p>

          <ul class="bring-problem-list">
            <li>Get direct input from people running API platforms</li>
            <li>Pressure-test your architecture and strategy</li>
            <li>Leave with clearer decisions, not just notes</li>
          </ul>

          <div class="bring-problem-actions">
            <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
            <a class="button secondary alt" href={speakerUrl}>Bring an APIOps Problem</a>
          </div>
          <p class="bring-problem-footnote">
            No vendor talks. No generic presentations.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section agenda-showcase" id="agenda">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>Agenda</h2>
          <p>Where we go deep on <strong>actual API decisions.</strong></p>
          <p>This is APIOps applied — not theory.</p>
        </div>

        <div class="agenda-days">
          {agenda.map((day) => (
            <article class="agenda-panel agenda-modern">
              <div class="agenda-panel-header agenda-modern-header">
                <h3>
                  <span class={`day-pill agenda-day ${day.color === "orange" ? "day-pill-orange" : "day-pill-blue"}`}>
                    {day.date}
                  </span>
                  {day.theme}
                </h3>
              </div>

              <ul class="agenda-modern-list">
                {day.items.map((item) => (
                  <li class={`agenda-modern-row ${item.tracks ? "is-tracks" : "is-shared"}`}>
                    <div class="agenda-modern-time">{item.time}</div>

                    {item.tracks ? (
                      <div class="agenda-modern-tracks">
                        {["a", "b", "workshop"].map((key) => {
                          const block = item.tracks[key];
                          if (!block?.title && !block?.speaker) return null;

                          return (
                            <div class="agenda-modern-item">
                              <div class="agenda-modern-meta">
                                <span class="agenda-modern-track">
                                  {key === "a" ? "Track A" : key === "b" ? "Track B" : "Workshop"}
                                </span>
                                {block.sessionType && (
                                  <span class={`session-type session-type-${getSessionTone(block.sessionType)}`}>
                                    {block.sessionType}
                                  </span>
                                )}
                              </div>

                              <div class="agenda-topic">{block.title}</div>
                              {block.speaker && <div class="agenda-speaker">{block.speaker}</div>}
                              {block.takeaway && <div class="agenda-takeaway">→ {block.takeaway}</div>}
                            </div>
                          );
                        })}
                      </div>
                    ) : (
                      <div class="agenda-modern-item agenda-modern-item-shared">
                        <div class="agenda-modern-meta">
                          <span class="agenda-modern-track">Shared session</span>
                          {getSharedSessionType(item) && (
                            <span class={`session-type session-type-${getSessionTone(getSharedSessionType(item))}`}>
                              {getSharedSessionType(item)}
                            </span>
                          )}
                        </div>

                        <div class="agenda-topic">{item.title}</div>
                        {item.speaker && <div class="agenda-speaker">{item.speaker}</div>}
                        {item.takeaway && <div class="agenda-takeaway">→ {item.takeaway}</div>}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section speakers-showcase" id="speakers">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>Speakers & Hosts</h2>
          <p>Direct experience, not vendor marketing.</p>
          <p>People doing APIOps in real organizations — not talking about it.</p>
        </div>

        <div class="grid speaker-grid speaker-grid-modern">
          {speakers.map((speaker) => (
            <article class="speaker-card-modern">
              <div class="speaker-avatar speaker-avatar-modern">
                {speaker.avatar ? (
                  <img src={speaker.avatar} alt={`Portrait of ${speaker.name}`} loading="lazy" />
                ) : (
                  speaker.name
                    .split(" ")
                    .map((name) => name[0])
                    .join("")
                )}
              </div>

              <h3>{speaker.name}</h3>
              <p class="speaker-role">{speaker.title}, {speaker.company}</p>
              <p class="speaker-bio speaker-bio-clamped">{speaker.bio}</p>
            </article>
          ))}
        </div>

        <div class="section-cta-row">
          <a class="button primary" href={speakerUrl}>Contribute a Problem or Experience</a>
        </div>
        <p class="case-microcopy center">Bring a real APIOps challenge: API, IAM, platform, or governance. No vendor talks.</p>
      </div>
    </div>
  </section>

  <section class="section sponsors-showcase" id="partners">
    <div class="container">
      <div class="section-shell">
        <div class="sponsors-layout">
          <div class="sponsors-copy">
            <div class="section-title section-title-left section-title-compact">
              <h2>Sponsors</h2>
              <p>
                APIOps Helsinki is supported by respected companies working with teams building real
                <strong> API platforms.</strong>
              </p>
            </div>

            <div class="sponsor-tier-group sponsor-tier-group-modern">
              <span class="sponsor-tier-label">Featured</span>

              <div class="sponsor-logo-grid">
                {[...sponsors.gold, ...sponsors.silver, ...sponsors.community].map((sponsor) => (
                  <div class="sponsor-logo-card sponsor-card">
                    {sponsor.url ? (
                      <a href={sponsor.url} target="_blank" rel="noreferrer">
                        {sponsor.logo ? (
                          <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" />
                        ) : (
                          <span class="sponsor-fallback-name">{sponsor.name}</span>
                        )}
                      </a>
                    ) : sponsor.logo ? (
                      <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" />
                    ) : (
                      <span class="sponsor-fallback-name">{sponsor.name}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <aside class="sponsor-cta-card">
            <h3>Partner With Us, Too</h3>
            <p>
              Building API reliability, governance, and AI-ready platform capability matters in the next 1–2
              years. Show your support in front of the right audience.
            </p>

            <div class="section-cta-row section-cta-row-left">
              <a class="button secondary alt" href={partnerUrl}>Become a Sponsor</a>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-band cta-section">
    <div class="container">
      <h2>Don’t attend to listen. Attend to figure things out.</h2>
      <p>
        Bring a real APIOps problem. Work through it with people solving similar challenges. Leave with decisions you
        can act on.
      </p>
      <div class="hero-actions cta-actions">
        <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
        <a class="button secondary" href={speakerUrl}>Bring an APIOps Problem</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <h4>APIOps Helsinki 2026</h4>
        <p>Epicenter Helsinki · June 2–3, 2026</p>
        <p>A working conference on API design, governance, and platform strategy.</p>
      </div>
      <div>
        <h4>Conference</h4>
        <a href="#agenda">Agenda</a>
        <a href="#speakers">Speakers</a>
        <a href="#partners">Partners</a>
      </div>
      <div>
        <h4>Community</h4>
        <a href="#who-for">Who Should Attend</a>
