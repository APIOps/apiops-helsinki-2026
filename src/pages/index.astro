---
import BaseLayout from "../layouts/BaseLayout.astro";
import agenda from "../data/agenda.json";
import speakers from "../data/speakers.json";
import sponsors from "../data/sponsors.json";

const ticketUrl = "https://shop.osaango.com/category/apiops-helsinki-2026";
const speakerUrl = "https://tally.so/r/LZW5kO";
const partnerUrl =
  "https://docs.google.com/presentation/d/1bXmS1AlfLN40FQ6Ws6ldm9BffD1sS_BW/edit?usp=sharing&ouid=108887358045542967446&rtpof=true&sd=true";

const whoFor = [
  "Owning or building an API platform in an enterprise",
  "Designing APIs that will be used by AI agents or automation",
  "Responsible for API governance, IAM, or monetization",
  "Trying to align business, product, and platform teams",
];

const notFor = [
  "You want beginner-level API content",
  "You’re looking for vendor-heavy presentations",
  "You don’t have real API challenges to solve",
];

const formatBlocks = [
  {
    title: "Clinic",
    tag: "CLINIC",
    icon: "material-symbols-light:handyman-outline",
    body: "Bring your API, platform, or governance problem.",
    outcome: "Get direct input from experienced practitioners.",
    tone: "orange",
  },
  {
    title: "AI Lab",
    tag: "LAB",
    icon: "material-symbols-light:science-outline",
    body: "Test ideas around MCP, agent integrations, and AI workflows.",
    outcome: "Understand what actually works (and what breaks).",
    tone: "purple",
  },
  {
    title: "Unconference",
    tag: "UNCONFERENCE",
    icon: "material-symbols-light:sync-outline",
    body: "Topics are shaped by participants.",
    outcome: "Discuss what matters now, not what was planned months ago.",
    tone: "blue",
  },
];

const whyEventExists = [
  {
    icon: "material-symbols-light:smart-toy-outline",
    title: "AI agents are consuming APIs differently",
    text: "Most APIs were built for apps. Autonomy brings new types of requests.",
  },
  {
    icon: "material-symbols-light:api",
    title: "APIs designed for apps are breaking under AI agents",
    text: "Long-tail identity, access, and governance issues are hitting hard.",
  },
  {
    icon: "material-symbols-light:warning-outline",
    title: "Identity, access, and contracts are critical bottlenecks",
    text: "You can’t afford to be loose with who or what can call your APIs.",
  },
  {
    icon: "material-symbols-light:note-stack-outline",
    title: "Most API strategies weren’t built for this era",
    text: "You’ll need to rethink your approach before things break.",
  },
];

const systemMap = [
  { title: "Identity", icon: "material-symbols-light:badge-outline" },
  { title: "Access", icon: "material-symbols-light:lock-outline" },
  { title: "Contracts", icon: "material-symbols-light:rule-outline" },
  { title: "APIs", icon: "material-symbols-light:api", featured: true },
  { title: "AI Agents", icon: "material-symbols-light:smart-toy-outline" },
  { title: "Platforms", icon: "material-symbols-light:deployed-code-outline" },
  { title: "Business", icon: "material-symbols-light:business-center-outline" },
];

const coverTopics = [
  {
    title: "Strategy",
    body: "Platform and product realignment",
    icon: "material-symbols-light:layers-outline",
  },
  {
    title: "Identity",
    body: "Auth for agents and machines",
    icon: "material-symbols-light:shield-lock-outline",
  },
  {
    title: "Monetization",
    body: "New models and metrics",
    icon: "material-symbols-light:euro-outline",
  },
  {
    title: "AI Agents",
    body: "MCP, autonomy, and safeguards",
    icon: "material-symbols-light:smart-toy-outline",
  },
];

const sessionToneMap = {
  KEYNOTE: "orange",
  "CASE STUDY": "purple",
  PANEL: "slate",
  CLINIC: "orange",
  "HANDS-ON": "purple",
  WORKSHOP: "purple",
  LAB: "purple",
  UNCONFERENCE: "blue",
  BREAK: "soft",
  LUNCH: "soft",
  CLOSING: "soft",
};

function getSessionTone(type) {
  return sessionToneMap[type] || "soft";
}

function inferSessionType(title = "") {
  const t = title.toLowerCase();

  if (t.includes("keynote")) return "KEYNOTE";
  if (t.includes("panel")) return "PANEL";
  if (t.includes("clinic")) return "CLINIC";
  if (t.includes("lab")) return "LAB";
  if (t.includes("unconference")) return "UNCONFERENCE";
  if (t.includes("hands-on")) return "HANDS-ON";
  if (t.includes("workshop")) return "WORKSHOP";
  if (t.includes("break")) return "BREAK";
  if (t.includes("lunch")) return "LUNCH";
  if (t.includes("closing")) return "CLOSING";

  return "";
}

function getSharedSessionType(item) {
  return item.sessionType || inferSessionType(item.title || "");
}
---

<BaseLayout title="APIOps Helsinki Conference 2026">
  <nav>
    <div class="container nav-inner">
      <div class="brand">
        <img class="brand-logo" src="/favicon.svg" alt="APIOps Helsinki logo" />
        <strong>APIOps Helsinki</strong>
      </div>

      <button
        class="nav-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="top-navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-links" id="top-navigation">
        <a href="#agenda">Agenda</a>
        <a href="#format">Format</a>
        <a href="#speakers">Speakers</a>
        <a href="#partners">Partners</a>
        <a href={ticketUrl}>Tickets</a>
        <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
      </div>
    </div>
  </nav>

  <script>
    const navToggle = document.querySelector(".nav-toggle");
    const navLinks = document.querySelector(".nav-links");

    navToggle?.addEventListener("click", () => {
      navLinks?.classList.toggle("is-open");
      const isExpanded = navLinks?.classList.contains("is-open") || false;
      navToggle.setAttribute("aria-expanded", String(isExpanded));
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 720 && navLinks?.classList.contains("is-open")) {
        navLinks.classList.remove("is-open");
        navToggle?.setAttribute("aria-expanded", "false");
      }
    });
  </script>
  <script
    is:inline
    type="module"
    src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>

  <header class="hero hero-clean">
    <div class="container hero-layout">
      <div class="hero-copy">
        <span class="hero-kicker">June 2–3, 2026 · Epicenter Helsinki</span>
        <h1>APIs Are Becoming<br />The Control Layer for AI.</h1>
        <p class="hero-meta">Most Organizations Aren’t Ready.</p>
        <p>
          A working conference for people building, governing, and monetizing API platforms in the age of AI
          agents.
        </p>
        <p>
          This is not a passive event. You’ll challenge assumptions, bring real problems, and leave with
          clearer decisions.
        </p>

        <div class="hero-actions">
          <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
          <a class="button secondary" href={speakerUrl}>Apply to Speak / Run a Session</a>
        </div>

        <div class="hero-proof is-hidden">
          <span>Trusted by teams from</span>
          <div class="hero-proof-logos">
            <span>OP Financial Group</span>
            <span>ASSA ABLOY</span>
            <span>If Insurance</span>
            <span>Apiable</span>
          </div>
        </div>
      </div>

      <div class="hero-map" aria-hidden="true">
        <div class="hero-map-core">APIs</div>
        {systemMap
          .filter((item) => !item.featured)
          .map((item) => (
            <div class={`hero-map-node hero-map-node-${item.title.toLowerCase().replaceAll(" ", "-")}`}>
              <iconify-icon icon={item.icon}></iconify-icon>
              <span>{item.title}</span>
            </div>
          ))}
      </div>
    </div>
  </header>

  <section class="section section-light section-why" id="positioning">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>Why This Event Exists</h2>
        </div>

        <div class="why-grid">
          {whyEventExists.map((item, index) => (
            <article class={`surface-card why-card ${index >= 2 ? "surface-card-soft" : ""}`}>
              <iconify-icon icon={item.icon} class="card-icon"></iconify-icon>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section section-soft" id="who-for">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>Who This Is For</h2>
        </div>

        <div class="audience-grid">
          <article class="surface-card audience-card">
            <div class="audience-card-title">
              <iconify-icon icon="material-symbols-light:check-circle-outline"></iconify-icon>
              <h3>If You Are:</h3>
            </div>
            <ul>
              {whoFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>

          <article class="surface-card audience-card audience-card-muted">
            <div class="audience-card-title">
              <iconify-icon icon="material-symbols-light:cancel-outline"></iconify-icon>
              <h3>This Is NOT for You If:</h3>
            </div>
            <ul>
              {notFor.map((item) => <li>{item}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-soft" id="format">
    <div class="container">
      <div class="section-shell">
        <div class="format-top">
          <div class="format-intro">
            <h2>Two Days. One Goal.<br />Make Better API Decisions.</h2>
            <div class="format-signals">
              <div><iconify-icon icon="material-symbols-light:forum-outline"></iconify-icon><span>No slides without consequences</span></div>
              <div><iconify-icon icon="material-symbols-light:domain-verification-outline"></iconify-icon><span>Real problems from real teams</span></div>
              <div><iconify-icon icon="material-symbols-light:groups-outline"></iconify-icon><span>Workshops, clinics, open labs</span></div>
              <div><iconify-icon icon="material-symbols-light:smart-toy-outline"></iconify-icon><span>People building what’s next</span></div>
            </div>
          </div>

          <div class="format-cards">
            {formatBlocks.map((item) => (
              <article class={`surface-card format-card surface-card-accent-${item.tone}`}>
                <div class="format-card-top">
                  <iconify-icon icon={item.icon} class="card-icon"></iconify-icon>
                  <span class={`session-type session-type-${item.tone}`}>{item.tag}</span>
                </div>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
                <p class="arrow-line">→ {item.outcome}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-light section-system-map" id="program-narrative">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>What We’ll Cover</h2>
        </div>

        <div class="cover-grid">
          {coverTopics.map((item) => (
            <article class="surface-card cover-card">
              <iconify-icon
                icon={item.icon}
                class={`card-icon ${
                  item.title === "Identity"
                    ? "identity"
                    : item.title === "Monetization"
                      ? "monetization"
                      : item.title === "AI Agents"
                        ? "ai"
                        : ""
                }`}></iconify-icon>
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section agenda-showcase" id="agenda">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>Agenda</h2>
          <p>Where we go deep on <strong>actual API decisions.</strong></p>
        </div>

        <div class="agenda-days">
          {agenda.map((day) => (
            <article class="agenda-panel agenda-modern">
              <div class="agenda-panel-header agenda-modern-header">
                <h3>
                  <span class={`day-pill agenda-day ${day.color === "orange" ? "day-pill-orange" : "day-pill-blue"}`}>
                    {day.date}
                  </span>
                  {day.theme}
                </h3>
              </div>

              <ul class="agenda-modern-list">
                {day.items.map((item) => (
                  <li class={`agenda-modern-row ${item.tracks ? "is-tracks" : "is-shared"}`}>
                    <div class="agenda-modern-time">{item.time}</div>

                    {item.tracks ? (
                      <div class="agenda-modern-tracks">
                        {["a", "b", "workshop"].map((key) => {
                          const block = item.tracks[key];
                          if (!block?.title && !block?.speaker) return null;

                          return (
                            <div class="agenda-modern-item">
                              <div class="agenda-modern-meta">
                                <span class="agenda-modern-track">
                                  {key === "a" ? "Track A" : key === "b" ? "Track B" : "Workshop"}
                                </span>
                                {block.sessionType && (
                                  <span class={`session-type session-type-${getSessionTone(block.sessionType)}`}>
                                    {block.sessionType}
                                  </span>
                                )}
                              </div>

                              <div class="agenda-topic">{block.title}</div>
                              {block.speaker && <div class="agenda-speaker">{block.speaker}</div>}
                              {block.takeaway && <div class="agenda-takeaway">→ {block.takeaway}</div>}
                            </div>
                          );
                        })}
                      </div>
                    ) : (
                      <div class="agenda-modern-item agenda-modern-item-shared">
                        <div class="agenda-modern-meta">
                          <span class="agenda-modern-track">Shared session</span>
                          {getSharedSessionType(item) && (
                            <span class={`session-type session-type-${getSessionTone(getSharedSessionType(item))}`}>
                              {getSharedSessionType(item)}
                            </span>
                          )}
                        </div>

                        <div class="agenda-topic">{item.title}</div>
                        {item.speaker && <div class="agenda-speaker">{item.speaker}</div>}
                        {item.takeaway && <div class="agenda-takeaway">→ {item.takeaway}</div>}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section speakers-showcase" id="speakers">
    <div class="container">
      <div class="section-shell">
        <div class="section-title section-title-left section-title-compact">
          <h2>Speakers & Hosts</h2>
          <p>Direct experience, not vendor marketing.</p>
        </div>

        <div class="grid speaker-grid speaker-grid-modern">
          {speakers.map((speaker) => (
            <article class="speaker-card-modern">
              <div class="speaker-avatar speaker-avatar-modern">
                {speaker.avatar ? (
                  <img src={speaker.avatar} alt={`Portrait of ${speaker.name}`} loading="lazy" />
                ) : (
                  speaker.name
                    .split(" ")
                    .map((name) => name[0])
                    .join("")
                )}
              </div>

              <h3>{speaker.name}</h3>
              <p class="speaker-role">{speaker.title}, {speaker.company}</p>
              <p class="speaker-bio speaker-bio-clamped">{speaker.bio}</p>
            </article>
          ))}
        </div>

        <div class="section-cta-row">
          <a class="button primary" href={speakerUrl}>Apply to Speak</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section sponsors-showcase" id="partners">
    <div class="container">
      <div class="section-shell">
        <div class="sponsors-layout">
          <div class="sponsors-copy">
            <div class="section-title section-title-left section-title-compact">
              <h2>Sponsors</h2>
              <p>
                APIOps Helsinki is supported by respected companies helping shape the future of
                <strong> API platforms.</strong>
              </p>
            </div>

            <div class="sponsor-tier-group sponsor-tier-group-modern">
              <span class="sponsor-tier-label">Featured</span>

              <div class="sponsor-logo-grid">
                {[...sponsors.gold, ...sponsors.silver, ...sponsors.community].map((sponsor) => (
                  <div class="sponsor-logo-card sponsor-card">
                    {sponsor.url ? (
                      <a href={sponsor.url} target="_blank" rel="noreferrer">
                        {sponsor.logo ? (
                          <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" />
                        ) : (
                          <span class="sponsor-fallback-name">{sponsor.name}</span>
                        )}
                      </a>
                    ) : sponsor.logo ? (
                      <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" />
                    ) : (
                      <span class="sponsor-fallback-name">{sponsor.name}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <aside class="sponsor-cta-card">
            <h3>Partner With Us, Too</h3>
            <p>
              Building API reliability, governance, and AI-ready platform capability matters in the next 1–2
              years. Show your support in front of the right audience.
            </p>

            <div class="section-cta-row section-cta-row-left">
              <a class="button secondary alt" href={partnerUrl}>Become a Sponsor</a>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>

  <section class="section cta-band cta-section">
    <div class="container">
      <h2>Don’t attend to listen. Attend to figure things out.</h2>
      <p>Bring a real API challenge. Get input from people solving similar problems. Leave with clearer decisions.</p>
      <div class="hero-actions cta-actions">
        <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
        <a class="button secondary" href={speakerUrl}>Apply to Speak or Run a Session</a>
        <a class="button secondary" href={partnerUrl}>Partnerships</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <h4>APIOps Helsinki 2026</h4>
        <p>Epicenter Helsinki · June 2–3, 2026</p>
        <p>Organized by Osaango in partnership with APIdays.</p>
      </div>
      <div>
        <h4>Conference</h4>
        <a href="#agenda">Agenda</a>
        <a href="#speakers">Speakers</a>
        <a href="#partners">Partners</a>
      </div>
      <div>
        <h4>Community</h4>
        <a href="#who-for">Who Should Attend</a>
        <a href={partnerUrl}>Become a Partner</a>
      </div>
      <div>
        <h4>Tickets</h4>
        <a href={ticketUrl}>Get your ticket here</a>
      </div>
    </div>
  </footer>
</BaseLayout>
