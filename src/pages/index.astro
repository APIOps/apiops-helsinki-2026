---
import BaseLayout from "../layouts/BaseLayout.astro";
import highlights from "../data/highlights.json";
import agenda from "../data/agenda.json";
import speakers from "../data/speakers.json";
import sponsors from "../data/sponsors.json";
import site from "../data/site.json";

const ticketUrl = "https://shop.osaango.com/category/apiops-helsinki-2026";
const speakerUrl = "https://tally.so/r/LZW5kO";
const partnerUrl = "https://docs.google.com/presentation/d/1bXmS1AlfLN40FQ6Ws6ldm9BffD1sS_BW/edit?usp=sharing&ouid=108887358045542967446&rtpof=true&sd=true";

const whoFor = [
  "Owning or building an API platform in an enterprise",
  "Designing APIs that will be used by AI agents or automation",
  "Responsible for API governance, IAM, or monetization",
  "Trying to align business, product, and platform teams"
];

const notFor = [
  "You want beginner-level API content",
  "You’re looking for vendor-heavy presentations",
  "You don’t have real API challenges to solve"
];

const formatBlocks = [
  {
    title: "🛠 Clinics",
    icon: "material-symbols-light:handyman-outline",
    body: "Bring your API, platform, or governance problem.",
    outcome: "Get direct input from experienced practitioners."
  },
  {
    title: "🧪 AI Lab",
    icon: "material-symbols-light:science-outline",
    body: "Test ideas around MCP, agent integrations, and AI workflows.",
    outcome: "Understand what actually works (and what breaks)."
  },
  {
    title: "🔄 Guided Unconference",
    icon: "material-symbols-light:sync-outline",
    body: "Topics are shaped by participants.",
    outcome: "Discuss what matters now, not what was planned months ago."
  }
];

const whyEventExists = [
  {
    icon: "material-symbols-light:smart-toy-outline",
    text: "AI agents are changing how APIs are used (from apps → autonomous systems)."
  },
  {
    icon: "material-symbols-light:api-outline",
    text: "Identity, governance, and contracts are becoming critical bottlenecks."
  },
  {
    icon: "material-symbols-light:warning-outline",
    text: "Most API strategies were not designed for this shift."
  },
  {
    icon: "material-symbols-light:error-outline",
    text: "This conference helps you adapt before things break."
  }
];

const highlightIcons = [
  "material-symbols-light:layers-outline",
  "material-symbols-light:hub-outline",
  "material-symbols-light:gavel-outline"
];
---

<BaseLayout title="APIOps Helsinki Conference 2026">
  <nav>
    <div class="container nav-inner">
      <div>
        <strong>APIOps Helsinki</strong>
      </div>
      <button
        class="nav-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="top-navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
      <div class="nav-links" id="top-navigation">
        <a href="#agenda">Agenda</a>
        <a href="#format">Format</a>
        <a href="#speakers">Speakers</a>
        <a href="#partners">Partners</a>
        <a href={ticketUrl}>Tickets</a>
        <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
      </div>
    </div>
  </nav>

  <script>
    const navToggle = document.querySelector(".nav-toggle");
    const navLinks = document.querySelector(".nav-links");

    navToggle?.addEventListener("click", () => {
      navLinks?.classList.toggle("is-open");
      const isExpanded = navLinks?.classList.contains("is-open") || false;
      navToggle.setAttribute("aria-expanded", String(isExpanded));
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 720 && navLinks?.classList.contains("is-open")) {
        navLinks.classList.remove("is-open");
        navToggle?.setAttribute("aria-expanded", "false");
      }
    });
  </script>
  <script is:inline type="module" src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>

  <header class="hero" style={`--hero-image: url('${site.hero.backgroundImage}')`}>
    <div class="container hero-content wide">
      <span class="badge">June 2-3, 2026 · Epicenter Helsinki</span>
      <h1>APIOps Helsinki 2026</h1>
      <p class="meta">APIs Are Becoming the Control Layer for AI. Most Organizations Aren’t Ready.</p>
      <p>
        A working conference for people building, governing, and monetizing API platforms in the age of AI agents.
      </p>
      <p>
        This is not a passive event. You’ll challenge assumptions, bring real problems, and leave with clearer
        decisions.
      </p>
      <p class="hero-audience">👉 For API platform leaders, architects, and product owners navigating AI-driven change.</p>
      <div class="hero-actions">
        <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
        <a class="button secondary" href={speakerUrl}>Apply to Speak / Run a Session</a>
      </div>
    </div>
  </header>

  <section class="section strip-section" id="positioning">
    <div class="container">
      <h2>Why this event exists</h2>
      <ul class="strip-list">
        {whyEventExists.map((item) => (
          <li>
            <iconify-icon icon={item.icon} class="section-icon"></iconify-icon>
            <span>{item.text}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section" id="who-for">
    <div class="container">
      <div class="section-title">
        <h2>Who this is for</h2>
      </div>
      <div class="split audience-split single-row">
        <div class="card">
          <h3>If you are:</h3>
          <ul>
            {whoFor.map((item) => <li>{item}</li>)}
          </ul>
          <p class="arrow-line">→ You’ll find people facing the same problems.</p>
        </div>
        <div class="card not-for">
          <h3>This is NOT for you if:</h3>
          <ul>
            {notFor.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section highlight-row cosmic-band" id="tracks">
    <div class="container">
      <div class="section-title">
        <h2>Rapid Change Demands New Ideas</h2>
      </div>
      <div class="grid highlight-grid">
        {highlights.map((item, index) => (
          <div class="card">
            <iconify-icon icon={highlightIcons[index]} class="section-icon highlight-icon"></iconify-icon>
            <span class="badge">APIOps Focus</span>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section cosmic-band" id="format">
    <div class="container">
      <div class="section-title">
        <h2>Two Days. One Goal: Make Better API Decisions.</h2>
        <p>You don’t just listen. You participate.</p>
      </div>
      <div class="grid highlight-grid">
        {formatBlocks.map((item) => (
          <div class="card left-card">
            <iconify-icon icon={item.icon} class="section-icon format-icon"></iconify-icon>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <p class="arrow-line">→ {item.outcome}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section highlight-row cosmic-band" id="program-narrative">
    <div class="container">
      <div class="section-title">
        <h2>Two days. One goal: make better API decisions.</h2>
      </div>
      <div class="split single-row">
        <div class="card left-card">
          <h3><span class="day-pill day-pill-orange">June 2</span> Strategy &amp; Reality Check</h3>
          <p>Understand what is changing and where your current approach breaks.</p>
        </div>
        <div class="card left-card">
          <h3><span class="day-pill day-pill-blue">June 3</span> Apply, Test, and Challenge</h3>
          <p>Work through real problems with peers and experts.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section cosmic-band" id="agenda">
    <div class="container">
      <div class="section-title">
        <h2>APIOps Helsinki 2026 Program</h2>
        <p>June 2-3, 2026 · Epicenter Helsinki, Mikonkatu 9</p>
      </div>
      <div class="split" id="day">
        {agenda.map((day) => (
          <div class="card agenda-card">
            <div class={`agenda-header ${day.color}`}>
              {day.day}: {day.theme} · {day.date}
            </div>
            <div class="agenda-track-headings">
              <span class="track-heading">Time</span>
              <span class="track-heading">Track A</span>
              <span class="track-heading">Track B</span>
              <span class="track-heading">Workshop</span>
            </div>
            <ul class="agenda-list" id="day">
              {day.items.map((item) => (
                <li class={item.tracks ? "agenda-row has-tracks" : "agenda-row is-shared"}>
                  <span class="agenda-time">{item.time}</span>
                  {item.tracks ? (
                    <>
                      <div class="agenda-track-item">
                        <span class="agenda-track-label">Track A</span>
                        {item.tracks.a.sessionType && <span class="session-type">{item.tracks.a.sessionType}</span>}
                        <span class="agenda-topic">{item.tracks.a.title}</span>
                        {item.tracks.a.speaker && <span class="agenda-speaker">{item.tracks.a.speaker}</span>}
                        {item.tracks.a.takeaway && <span class="agenda-takeaway">→ {item.tracks.a.takeaway}</span>}
                      </div>
                      <div class="agenda-track-item">
                        <span class="agenda-track-label">Track B</span>
                        {item.tracks.b.sessionType && <span class="session-type">{item.tracks.b.sessionType}</span>}
                        <span class="agenda-topic">{item.tracks.b.title}</span>
                        {item.tracks.b.speaker && <span class="agenda-speaker">{item.tracks.b.speaker}</span>}
                        {item.tracks.b.takeaway && <span class="agenda-takeaway">→ {item.tracks.b.takeaway}</span>}
                      </div>
                      <div class="agenda-track-item">
                        <span class="agenda-track-label">Workshop</span>
                        {item.tracks.workshop.sessionType && <span class="session-type">{item.tracks.workshop.sessionType}</span>}
                        <span class="agenda-topic">{item.tracks.workshop.title}</span>
                        {item.tracks.workshop.speaker && <span class="agenda-speaker">{item.tracks.workshop.speaker}</span>}
                        {item.tracks.workshop.takeaway && <span class="agenda-takeaway">→ {item.tracks.workshop.takeaway}</span>}
                      </div>
                    </>
                  ) : (
                    <div class="agenda-shared-item">
                      <span class="agenda-track-label">Shared session</span>
                      {item.sessionType && <span class="session-type">{item.sessionType}</span>}
                      <span class="agenda-topic">{item.title}</span>
                      {item.speaker && <span class="agenda-speaker">{item.speaker}</span>}
                      {item.takeaway && <span class="agenda-takeaway">→ {item.takeaway}</span>}
                    </div>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="speakers">
    <div class="container">
      <div class="section-title">
        <h2>Learn from people doing the work</h2>
      </div>
      <div class="grid speaker-grid" id="name">
        {speakers.map((speaker) => (
          <div class="card speaker-card">
            <div class="speaker-avatar">
              {speaker.avatar ? (
                <img src={speaker.avatar} alt={`Portrait of ${speaker.name}`} loading="lazy" />
              ) : (
                speaker.name
                  .split(" ")
                  .map((name) => name[0])
                  .join("")
              )}
            </div>
            <h3>{speaker.name}</h3>
            <p>
              {speaker.title} @{speaker.company}
            </p>
            <p>{speaker.bio}</p>
          </div>
        ))}
      </div>
      <div style="text-align:center; margin-top: 2rem;">
        <a class="button primary" href={speakerUrl}>Apply to speak</a>
      </div>
    </div>
  </section>

  <section class="section highlight-row" id="partners">
    <div class="container">
      <div class="section-title">
        <h2>Supported by teams building real API platforms</h2>
        <p>These are the kinds of companies you’ll meet at the event.</p>
      </div>

      <div class="sponsor-tier-group">
        <h3 class="sponsor-tier-heading">Gold Sponsors</h3>
        <div class="grid sponsor-grid sponsor-grid-gold" style={`--tier-columns: ${Math.max(1, Math.min(3, sponsors.gold.length))};`}>
          {sponsors.gold.map((sponsor) => (
            <div class="card sponsor-card sponsor-card-gold">
              {sponsor.url ? (
                <a class="sponsor-link" href={sponsor.url} target="_blank" rel="noreferrer">
                  <div class="sponsor-media sponsor-media-gold">
                    {sponsor.logo ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" /> : <span class="sponsor-name">{sponsor.name}</span>}
                  </div>
                  <p class="sponsor-name">{sponsor.description}</p>
                </a>
              ) : (
                <>
                  <div class="sponsor-media sponsor-media-gold">
                    {sponsor.logo ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" /> : <span class="sponsor-name">{sponsor.name}</span>}
                  </div>
                  <p class="sponsor-name">{sponsor.description}</p>
                </>
              )}
            </div>
          ))}
        </div>
      </div>

      <div class="sponsor-tier-group">
        <h3 class="sponsor-tier-heading">Silver Sponsors</h3>
        <div class="grid sponsor-grid sponsor-grid-silver" style={`--tier-columns: ${Math.max(1, Math.min(4, sponsors.silver.length))};`}>
          {sponsors.silver.map((sponsor) => (
            <div class="card sponsor-card">
              {sponsor.url ? (
                <a class="sponsor-link" href={sponsor.url} target="_blank" rel="noreferrer">
                  <div class="sponsor-media">
                    {sponsor.logo ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" /> : <span class="sponsor-name">{sponsor.name}</span>}
                  </div>
                  <p class="sponsor-name">{sponsor.description}</p>
                </a>
              ) : (
                <>
                  <div class="sponsor-media">
                    {sponsor.logo ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" /> : <span class="sponsor-name">{sponsor.name}</span>}
                  </div>
                  <p class="sponsor-name">{sponsor.description}</p>
                </>
              )}
            </div>
          ))}
        </div>
      </div>

      <div class="sponsor-tier-group">
        <h3 class="sponsor-tier-heading">Community Sponsors</h3>
        <div class="grid sponsor-grid sponsor-grid-community" style={`--tier-columns: ${Math.max(1, Math.min(5, sponsors.community.length))};`}>
          {sponsors.community.map((sponsor) => (
            <div class="card sponsor-card">
              {sponsor.url ? (
                <a class="sponsor-link" href={sponsor.url} target="_blank" rel="noreferrer">
                  <div class="sponsor-media">
                    {sponsor.logo ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" /> : <span class="sponsor-name">{sponsor.name}</span>}
                  </div>
                  <p class="sponsor-name">{sponsor.description}</p>
                </a>
              ) : (
                <>
                  <div class="sponsor-media">
                    {sponsor.logo ? <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" /> : <span class="sponsor-name">{sponsor.name}</span>}
                  </div>
                  <p class="sponsor-name">{sponsor.description}</p>
                </>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="outcomes">
    <div class="container">
      <div class="section-title">
        <h2>What people typically figure out here</h2>
      </div>
      <div class="grid highlight-grid">
        <div class="card left-card"><p>“Our API strategy doesn’t work for AI agents.”</p></div>
        <div class="card left-card"><p>“We need to rethink IAM as a platform layer.”</p></div>
        <div class="card left-card"><p>“We’ve been over-investing in the wrong abstractions.”</p></div>
        <div class="card left-card"><p>“We finally understand how to monetize APIs.”</p></div>
      </div>
    </div>
  </section>

  <section class="section cta-band">
    <div class="container">
      <h2>Don’t attend to listen. Attend to figure things out.</h2>
      <p>Bring a real API challenge. Get input from people solving similar problems. Leave with clearer decisions.</p>
      <div class="hero-actions" style="justify-content:center; margin-top: 1.5rem;">
        <a class="button primary" href={ticketUrl}>Get Your Ticket</a>
        <a class="button secondary" href={speakerUrl}>Apply to Speak or Run a Session</a>
        <a class="button secondary" href={partnerUrl}>Partnerships</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <h4>APIOps Helsinki 2026</h4>
        <p>Epicenter Helsinki · June 2-3, 2026</p>
        <p>Organized by Osaango in partnership with APIdays.</p>
      </div>
      <div>
        <h4>Conference</h4>
        <a href="#agenda">Agenda</a>
        <a href="#speakers">Speakers</a>
        <a href="#partners">Partners</a>
      </div>
      <div>
        <h4>Community</h4>
        <a href="#who-for">Who Should Attend</a>
        <a href={partnerUrl}>Become a Partner</a>
      </div>
      <div>
        <h4>Tickets</h4>
        <a href={ticketUrl}>Get your ticket here</a>
      </div>
    </div>
  </footer>
</BaseLayout>
