---
import BaseLayout from "../layouts/BaseLayout.astro";
import events from "../data/events.json";

const upcomingEvents = events.filter((event) => event.status !== "Past event");
const pastEvents = events.filter((event) => event.status === "Past event");
const featuredEvents = upcomingEvents.slice(0, 3);
const parisEvent = events.find((event) => event.id === "paris-2026");
const joinUrl = "https://join.apiops.info/";

const communityFormats = [
  "APIOps Cycles workshops",
  "Conference talks",
  "Full-day working events",
  "Webinars",
  "Meetups",
  "Program contributor sessions",
  "Peer problem-solving clinics",
  "Operating-model synthesis notes",
];

const focusAreas = [
  "API strategy and business language",
  "Platform adoption after API management",
  "Governance without bottlenecks",
  "Shadow APIs and portfolio visibility",
  "Security, privacy, legal, risk, and compliance",
  "AI-assisted API design and delivery",
  "B2B developer migration and partner change",
  "Production adoption metrics and evidence",
];

function getActionLabel(event) {
  if (event.status === "Get updates") return "Get updates";
  if (event.status === "Save the date") return "Save the date";
  return "Get ticket";
}
---

<BaseLayout
  title="APIOps Community - Operating Models for APIs"
  description="APIOps is a global community for practitioners improving the operating model behind APIs, integrations, platforms, governance, AI-ready digital capabilities, and API consumer adoption."
>
  <nav class="community-nav">
    <div class="container nav-inner">
      <a class="brand" href="/">
        <img class="brand-logo" src="/favicon-32x32.png" alt="APIOps logo" />
        <strong>APIOps Community</strong>
      </a>

      <button
        class="nav-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="top-navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-links" id="top-navigation">
        <a href="#events">Events</a>
        <a href="#cycles">APIOps Cycles</a>
        <a href="#formats">Formats</a>
        <a href="#community">Community</a>
        <a class="button primary" href="/events">View Upcoming Events</a>
      </div>
    </div>
  </nav>

  <script>
    const navToggle = document.querySelector(".nav-toggle");
    const navLinks = document.querySelector(".nav-links");

    navToggle?.addEventListener("click", () => {
      navLinks?.classList.toggle("is-open");
      const isExpanded = navLinks?.classList.contains("is-open") || false;
      navToggle.setAttribute("aria-expanded", String(isExpanded));
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 720 && navLinks?.classList.contains("is-open")) {
        navLinks.classList.remove("is-open");
        navToggle?.setAttribute("aria-expanded", "false");
      }
    });
  </script>

  <main class="community-page">
    <header class="community-hero">
      <div class="container community-hero-grid">
        <div class="community-hero-copy">
          <p class="community-eyebrow">Global APIOps community</p>
          <h1>Improve the operating model behind APIs.</h1>
          <p class="community-hero-lede">
            APIOps connects practitioners working on API strategy, integrations, platforms, governance,
            AI-ready digital capabilities, and API consumer adoption.
          </p>
          <div class="community-actions">
            <a class="button primary" href="/events">View Upcoming Events</a>
            <a class="button secondary" href={joinUrl}>Join the Community</a>
          </div>
        </div>

        <div class="community-hero-panel" aria-label="APIOps operating model map">
          <div class="community-system-map">
            <div class="community-map-grid"></div>
            <div class="community-map-panel"></div>

            <div class="community-system-core">
              <span>APIOps</span>
              <small>Operating model</small>
            </div>

            <div class="community-system-node community-node-strategy">
              <strong>Strategy</strong>
              <span>business language</span>
            </div>

            <div class="community-system-node community-node-platform">
              <strong>Platforms</strong>
              <span>paved road</span>
            </div>

            <div class="community-system-node community-node-governance">
              <strong>Governance</strong>
              <span>controls early</span>
            </div>

            <div class="community-system-node community-node-adoption">
              <strong>Adoption</strong>
              <span>product teams</span>
            </div>

            <div class="community-system-node community-node-ai">
              <strong>AI-speed</strong>
              <span>without chaos</span>
            </div>

            <div class="community-system-node community-node-evidence">
              <strong>Evidence</strong>
              <span>production use</span>
            </div>

            <div class="community-touchpoint-card community-touchpoint-paris">
              <span>FULL EVENT</span>
              <strong>Paris</strong>
              <small>After API Management</small>
            </div>

            <div class="community-touchpoint-card community-touchpoint-workshops">
              <span>WORKSHOPS</span>
              <strong>Munich + India</strong>
              <small>APIOps Cycles</small>
            </div>

            <div class="community-touchpoint-card community-touchpoint-talks">
              <span>TALKS</span>
              <strong>Berlin + webinars</strong>
              <small>practitioner patterns</small>
            </div>

            <span class="community-map-glow community-map-glow-1"></span>
            <span class="community-map-glow community-map-glow-2"></span>
            <span class="community-map-glow community-map-glow-3"></span>
          </div>
        </div>
      </div>
    </header>

    <section class="community-signal-strip">
      <div class="container community-signal-grid">
        <div>
          <strong>Workshops</strong>
          <span>APIOps Cycles in practice</span>
        </div>
        <div>
          <strong>Talks</strong>
          <span>Practitioner patterns from API work</span>
        </div>
        <div>
          <strong>Events</strong>
          <span>Working rooms, not passive tracks</span>
        </div>
        <div>
          <strong>Online</strong>
          <span>Webinars, meetups, and notes</span>
        </div>
      </div>
    </section>

    <section class="section section-light" id="events">
      <div class="container">
        <div class="community-section-head">
          <p class="small-pill">Homepage section</p>
          <h2>Upcoming APIOps dates</h2>
          <p>
            The community shows up as APIOps Cycles workshops, talks, full events, webinars, meetups, and
            practitioner clinics. The next few confirmed touchpoints are listed here; the full calendar lives on
            the events page.
          </p>
        </div>

        <div class="community-home-calendar">
          {featuredEvents.map((event) => (
            <article class="community-date-card">
              <div class="community-date-tile">
                <span>{event.month}</span>
                <strong>{event.day}</strong>
                <small>{event.year}</small>
              </div>
              <div class="community-date-body">
                <div class="community-date-head">
                  <h3>{event.title}</h3>
                  <span class={`community-status-pill ${event.status.includes("Early") ? "is-early" : ""}`}>
                    {event.status}
                  </span>
                </div>
                <p class="community-event-meta">{event.location} - {event.mode} - {event.format}</p>
                <p>{event.description}</p>
                <div class="community-card-actions">
                  <a class="community-action-primary" href={event.ticketUrl}>{getActionLabel(event)}</a>
                  <a href={event.learnUrl}>Learn more</a>
                </div>
              </div>
            </article>
          ))}
        </div>

        {parisEvent && (
          <article class="community-featured-event">
            <div>
              <p>Featured full-day event</p>
              <h3>{parisEvent.title}</h3>
              <p class="community-event-meta">{parisEvent.date} - {parisEvent.location} - {parisEvent.mode} - {parisEvent.format}</p>
              <p>{parisEvent.description}</p>
              <div class="community-card-actions">
                <a class="community-action-primary is-purple" href={parisEvent.ticketUrl}>Get early-bird ticket</a>
                <a href={parisEvent.learnUrl}>Learn more</a>
              </div>
            </div>
            <div class="community-paris-sketch" aria-hidden="true"></div>
          </article>
        )}

        <div class="community-section-actions">
          <a class="button primary" href="/events">View full events calendar</a>
          <a class="button secondary alt" href={joinUrl}>Join the Community</a>
        </div>
      </div>
    </section>

    {pastEvents.length > 0 && (
      <section class="section section-soft">
        <div class="container community-two-column">
          <div>
            <p class="small-pill">Past events</p>
            <h2>Explore APIOps archives.</h2>
            <p>
              Completed community events include summaries, talks, speakers, materials, and photos where
              available.
            </p>
          </div>
          <div class="community-archive-list">
            {pastEvents.map((event) => (
              <article class="community-archive-card">
                <div class="community-date-tile">
                  <span>{event.month}</span>
                  <strong>{event.day}</strong>
                  <small>{event.year}</small>
                </div>
                <div>
                  <h3>{event.title}</h3>
                  <p class="community-event-meta">{event.date} - {event.location} - {event.mode}</p>
                  <p>{event.description}</p>
                  <a href={event.learnUrl}>View archive</a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="section community-image-band" id="cycles">
      <div class="container community-image-grid">
        <figure>
          <img src="/images/hero/apiops-helsinki2026-mike-jackson-allanknabe.jpg" alt="APIOps practitioners in conversation at a community event" loading="lazy" />
        </figure>
        <div>
          <p class="small-pill">APIOps Cycles</p>
          <h2>A shared map for better API operating-model conversations.</h2>
          <p>
            APIOps Cycles helps teams make the work behind APIs visible across business goals, platform
            architecture, governance, roles, legal, security, design, publishing, adoption, monitoring, and
            continuous improvement.
          </p>
          <p>
            APIOps Cycles is an open method - free to use, adapt, and share - which helps teams map API
            strategy, platforms, governance, and adoption. It is not a product or commercial framework.
          </p>
          <p>
            The goal is not to follow a method for its own sake. The goal is to create clearer decisions and
            reusable patterns for each organization.
          </p>
        </div>
      </div>
    </section>

    <section class="section section-soft" id="formats">
      <div class="container community-two-column">
        <div>
          <p class="small-pill">Formats</p>
          <h2>Different rooms, same operating-model focus.</h2>
          <p>
            APIOps community formats are designed for people who already have real API, integration, platform,
            governance, or adoption problems to solve.
          </p>
        </div>

        <div class="community-format-grid">
          {communityFormats.map((format) => (
            <span>{format}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-light">
      <div class="container">
        <div class="community-section-head">
          <p class="small-pill">Focus Areas</p>
          <h2>What the community works on.</h2>
          <p>
            These focus areas map to APIOps Cycles stations. At events, we use station stickers to help you find
            peers facing similar challenges.
          </p>
        </div>

        <div class="community-focus-grid">
          {focusAreas.map((item) => (
            <article>{item}</article>
          ))}
        </div>
      </div>
    </section>

    <section class="section community-join" id="community">
      <div class="container community-join-grid">
        <div>
          <p class="small-pill">Community</p>
          <h2>Bring real-world patterns, not product pitches.</h2>
          <p>
            APIOps is useful when practitioners share decisions, failure modes, stakeholder language, governance
            patterns, platform adoption lessons, and proof-capability examples others can reuse.
          </p>
        </div>
        <div class="community-join-card">
          <h3>What to bring</h3>
          <ul>
            <li>A real operating-model problem</li>
            <li>A pattern your team tested in practice</li>
            <li>A decision story others can learn from</li>
            <li>A question that deserves a working room</li>
          </ul>
          <a class="button primary" href={joinUrl}>Join the Community</a>
        </div>
      </div>
    </section>

    <section class="section cta-band cta-section">
      <div class="container">
        <h2>Next full APIOps event: Paris.</h2>
        <p>
          APIOps Paris 2026 is a full-day working conference on what happens after API management investment.
        </p>
          <div class="hero-actions cta-actions">
            <a class="button primary" href="/events">View Upcoming Events</a>
            <a class="button secondary" href={joinUrl}>Get Updates</a>
          </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <h4>APIOps Community</h4>
        <p>Operating models for APIs, integrations, platforms, governance, and AI-ready digital capabilities.</p>
      </div>
      <div>
        <h4>Events</h4>
        <a href="/events">Events calendar</a>
        <a href="https://www.apidays.global/events/munich">Munich</a>
        <a href="https://www.apidays.global/events/india">India</a>
        <a href="https://apiconference.net/berlin/">Berlin</a>
        <a href="/paris">Paris</a>
      </div>
      <div>
        <h4>Community</h4>
        <a href="#cycles">APIOps Cycles</a>
        <a href="#formats">Formats</a>
        <a href={joinUrl}>Join the Community</a>
      </div>
    </div>
  </footer>
</BaseLayout>
