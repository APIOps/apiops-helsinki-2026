---
import BaseLayout from "../layouts/BaseLayout.astro";
import sponsors from "../data/sponsors.json";

const storeLinks = {
  earlyBird: "https://www.eventbrite.com/e/apiops-helsinki-2026-tickets-1985901765640",
  regular: "https://www.eventbrite.com/e/apiops-helsinki-2026-tickets-1985901765640",
  academic: "https://www.eventbrite.com/e/apiops-helsinki-2026-tickets-1985901765640",
  caseApply: "https://tally.so/r/Zjl5ey",
};
---

<BaseLayout title="Participation options — APIOps Helsinki 2026">
  <nav>
    <div class="container nav-inner">
      <div class="brand">
        <img class="brand-logo" src="/favicon-32x32.png" alt="APIOps Helsinki logo" />
        <strong>APIOps Helsinki</strong>
      </div>

      <button
        class="nav-toggle"
        type="button"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="top-navigation"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="nav-links" id="top-navigation">
        <a href="/#agenda">Agenda</a>
        <a href="/#format">Format</a>
        <a href="/#speakers">Speakers</a>
        <a href="/partners">Partners</a>
        <a href="/tickets">Tickets</a>
        <a class="button primary" href="#standard-tickets">Register</a>
      </div>
    </div>
  </nav>

  <script>
    const navToggle = document.querySelector(".nav-toggle");
    const navLinks = document.querySelector(".nav-links");

    navToggle?.addEventListener("click", () => {
      navLinks?.classList.toggle("is-open");
      const isExpanded = navLinks?.classList.contains("is-open") || false;
      navToggle.setAttribute("aria-expanded", String(isExpanded));
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 720 && navLinks?.classList.contains("is-open")) {
        navLinks.classList.remove("is-open");
        navToggle?.setAttribute("aria-expanded", "false");
      }
    });
  </script>

  <section class="hero hero-small">
    <div class="container tickets-hero-content">
      <h1>Choose how you participate</h1>
      <p>This is a working event. Access depends on how you contribute.</p>
    </div>
  </section>

  
  <section class="section section-light">
    <div class="container narrow">
      <div class="ticket-explainer">
        <h3>How access works</h3>

        <ul>
          <li>Standard tickets are available to anyone</li>
          <li>Some participants join through curated invitations</li>
          <li>Working sessions are limited to ensure quality discussions</li>
          <li>Partner organizations may have special access opportunities</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-light" id="standard-tickets">
    <div class="container">
      <div class="section-title">
        <h2>Standard tickets</h2>
        <p>Join as an attendee.</p>
      </div>

      <div class="ticket-grid">
        <article class="ticket-card ticket-card-bookmarked">
          <h3>Early Bird - until Apr 30</h3>
          <p class="price">€495</p>
          <p>Limited availability</p>
          <a href={storeLinks.earlyBird} class="button primary">Buy ticket</a>
        </article>

        <article class="ticket-card">
          <h3>Regular</h3>
          <p class="price">€694 or 2 for 1 until May 30th</p>
          <p>Full conference access</p>
          <a href={storeLinks.regular} class="button primary">Buy ticket</a>
        </article>

        <article class="ticket-card">
          <h3>Academic / Unemployed</h3>
          <p class="price">€50</p>
          <p>Limited availability</p>
          <a href={storeLinks.academic} class="button secondary alt">Apply / Buy</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container narrow">
      <div class="section-title">
        <h2>Earn a free ticket - Bring an APIOps problem</h2>
        <p>Work on a real API, IAM, or platform challenge with peers.</p>
      </div>

      <div class="ticket-cta-card">
        <p>Selected participants can join working sessions, clinics, and labs with real problems.</p>

        <ul>
          <li>Get feedback from experienced practitioners</li>
          <li>Pressure-test your approach</li>
          <li>Leave with concrete decisions</li>
        </ul>

        <a href={storeLinks.caseApply} class="button primary">Apply to bring a case</a>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container narrow">
      <div class="section-title">
        <h2>Team participation - special pricing</h2>
        <p>This event works best when you attend as a cross-functional team.</p>
      </div>

      <div class="ticket-cta-card ticket-cta-card-bookmarked">
        <p>
          Bring 2–4 people across platform, IAM, architecture, and product.
          Use the event to align faster, pressure-test decisions, and avoid “conference → no change”.
        </p>

        <ul>
          <li>Align faster across roles</li>
          <li>Make decisions on the spot</li>
          <li>Work on shared API platform challenges</li>
        </ul>

        <a href="https://tally.so/r/Zjl52A" class="button secondary alt">
          Request team participation
        </a>

        <p class="ticket-note">
          We review team requests individually to keep the event relevant and high-signal.
        </p>
      </div>
    </div>
  </section>


  
  <section class="section sponsors-showcase" id="partners">
    <div class="container">
      <div class="section-shell">
        <div class="sponsors-layout">
          <div class="sponsors-copy">
            <div class="section-title section-title-left section-title-compact">
              <h2>Partners</h2>
              <p>
                APIOps Helsinki is supported by respected companies working with teams building real
                <strong> API platforms.</strong>
              </p>
            </div>

            <div class="sponsor-tier-group sponsor-tier-group-modern">
              <span class="sponsor-tier-label">Featured</span>

              <div class="sponsor-logo-grid">
                {[...sponsors.gold, ...sponsors.silver, ...sponsors.community].map((sponsor) => (
                  <div class="sponsor-logo-card sponsor-card">
                    {sponsor.url ? (
                      <a href={sponsor.url} target="_blank" rel="noreferrer">
                        {sponsor.logo ? (
                          <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" />
                        ) : (
                          <span class="sponsor-fallback-name">{sponsor.name}</span>
                        )}
                      </a>
                    ) : sponsor.logo ? (
                      <img src={sponsor.logo} alt={`${sponsor.name} logo`} loading="lazy" />
                    ) : (
                      <span class="sponsor-fallback-name">{sponsor.name}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>

          <aside class="sponsor-cta-card">
            <h3>Partner With Us, Too</h3>
            <p>
              Building API reliability, governance, and AI-ready platform capability matters in the next 1–2
              years. Show your support in front of the right audience.
            </p>

            <div class="section-cta-row section-cta-row-left">
              <a class="button secondary alt" href="/partners">Become a Partner</a>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>
  
  
  
</BaseLayout>
