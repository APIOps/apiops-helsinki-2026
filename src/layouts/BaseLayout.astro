---
import "../styles/global.css";

const { title = "APIOps Helsinki 2026" } = Astro.props;
const defaultOgImage = new URL(import.meta.env.PUBLIC_DEFAULT_OG_IMAGE, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="APIOps Helsinki Conference 2026 brings together API leaders, platform teams, and practitioners for two days of strategy, AI-driven APIs, and community co-creation."
    />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="APIOps Helsinki Conference 2026 brings together API leaders, platform teams, and practitioners for two days of strategy, AI-driven APIs, and community co-creation."
    />
    <meta property="og:image" content={defaultOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={defaultOgImage} />
  </head>
  <body>
    <slot />
  </body>
</html>